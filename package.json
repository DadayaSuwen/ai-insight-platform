{
  "name": "ai-insight-platform",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:web": "pnpm --filter @ai-insight/web dev",
    "dev:server": "pnpm --filter @ai-insight/server dev",
    "dev:all": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:up": "docker-compose up -d postgres",
    "db:seed": "pnpm --filter @ai-insight/server prisma db push && pnpm --filter @ai-insight/server ts-node prisma/seed.ts",
    "db:studio": "pnpm --filter @ai-insight/server prisma studio"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "eslint": "^8.57.0",
    "typescript": "^5.4.0"
  },
  "packageManager": "pnpm@9.0.0"
}