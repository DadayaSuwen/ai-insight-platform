# Production deployment environment. Copy to .env before deploying.
NODE_ENV=production

POSTGRES_USER=app
POSTGRES_PASSWORD=change-this-to-a-long-random-password
POSTGRES_DB=ai_insight
DATABASE_HOST=postgres
DB_USER=app
DB_PASSWORD=change-this-to-a-long-random-password
DB_NAME=ai_insight
DATABASE_URL=postgresql://app:change-this-to-a-long-random-password@postgres:5432/ai_insight

JWT_SECRET=change-this-to-at-least-32-random-characters
DB_CONFIG_ENCRYPTION_KEY=replace-with-a-32-byte-base64-key
FRONTEND_ORIGIN=http://localhost:8080
VITE_API_BASE_URL=/
WEB_PORT=8080
INIT_SEED=false
