# Neon PostgreSQL (Railway server)
# Copy the connection string from Neon and keep sslmode=require.
DATABASE_URL=postgresql://neondb_owner:npg_xxx@ep-xxx.neon.tech/neondb?sslmode=require

# Server
PORT=3000
FRONTEND_ORIGIN=https://your-web-domain.up.railway.app

# JWT signing secret (at least 32 characters)
# openssl rand -base64 32
JWT_SECRET=replace-with-at-least-32-random-characters

# Data-source password encryption key (32-byte base64)
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
DB_CONFIG_ENCRYPTION_KEY=replace-with-a-32-byte-base64-key

# Optional first-boot behavior
INIT_SEED=false

# Frontend build-time API base. Nginx uses same-origin proxying.
VITE_API_BASE_URL=/
